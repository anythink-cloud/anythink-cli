<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <AssemblyName>anythink-mcp</AssemblyName>
    <RootNamespace>AnythinkMcp</RootNamespace>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <PackAsTool>true</PackAsTool>
    <!-- Web SDK disables packaging by default; re-enable it so the tool can be packed -->
    <IsPackable>true</IsPackable>
    <ToolCommandName>anythink-mcp</ToolCommandName>
    <PackageId>anythink-mcp</PackageId>
    <Version>1.0.0</Version>
    <Title>Anythink — all-in-one backend (MCP server)</Title>
    <Description>Anythink MCP server — manage the Anythink all-in-one backend (databases, authentication, data and search, users and roles, files, workflows, integrations, payments, and REST APIs) from AI assistants and agents. Replace stitched-together services with one streamlined backend-as-a-service, configured with a little help from AI.</Description>
    <PackageTags>anythink;baas;backend;backend-as-a-service;mcp;model-context-protocol;ai;ai-agent;llm;agent;database;rest-api;cli;workflows;authentication;files;payments</PackageTags>
    <Authors>Anythink</Authors>
    <PackageProjectUrl>https://github.com/anythink-cloud/anythink-cli</PackageProjectUrl>
    <RepositoryUrl>https://github.com/anythink-cloud/anythink-cli</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <!-- Pack the README so the MCP registry can verify ownership via its mcp-name marker -->
  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

  <!-- MCP SDK — stdio-based server with DI hosting -->
  <ItemGroup>
    <PackageReference Include="ModelContextProtocol" Version="0.2.0-preview.1" />
    <PackageReference Include="Microsoft.Extensions.Hosting" Version="8.0.1" />
  </ItemGroup>

  <!-- Allow MCP test project to access internal members -->
  <ItemGroup>
    <InternalsVisibleTo Include="AnythinkMcp.Tests" />
  </ItemGroup>

  <!-- Share client, models, and config from the CLI project -->
  <ItemGroup>
    <ProjectReference Include="../src/AnythinkCli.csproj" />
  </ItemGroup>

</Project>
