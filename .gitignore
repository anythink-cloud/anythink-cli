# Build output
bin/
obj/
dist/

# The npm wrapper's launcher is a source file living under bin/ — keep it tracked
# (the `bin/` rule above would otherwise ignore it). Downloaded native binaries
# in npm/bin/ stay ignored.
!npm/bin/
npm/bin/*
!npm/bin/anythink-mcp.js

# Test results and coverage reports
TestResults*/
*.coverage
*.coveragexml

# .NET tools
*.user
*.suo
.vs/

# Environment — never commit secrets or internal URLs
.env
.env.example

# IDE config
.idea/
.claude/

# publish.sh is replaced by .github/workflows/release.yml
publish.sh

# MCP config — contains absolute paths, generated per-machine
.mcp.json

# MCP debug logs
mcp_stderr.txt

# macOS
.DS_Store

# Local scratch / planning — internal notes, never published
BACKLOG.md
MIGRATIONS-PLAN.md
CLAUDE.md
