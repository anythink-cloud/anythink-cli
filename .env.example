# Anythink CLI - Environment Overrides
# Copy this to .env and uncomment variables to override production settings.

# Platform Management API base URL (e.g. http://localhost:5099)
# MYANYTHINK_API_URL=https://api.my.anythink.cloud

# Platform organization/tenant ID
# MYANYTHINK_ORG_ID=20804318

# Billing API base URL (e.g. http://localhost:5100)
# BILLING_API_URL=https://api.billing.anythink.cloud

# JWT access token for platform/billing commands (bypasses login)
# ANYTHINK_PLATFORM_TOKEN=your-jwt-here

# Preferred billing account ID (UUID)
# ANYTHINK_ACCOUNT_ID=a1b2c3d4-e5f6-7890-abcd-1234567890ab
