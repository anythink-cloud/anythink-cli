# .env is gitignored and never committed.

# Dev / staging environment
ANYTHINK_DEV_API=
ANYTHINK_DEV_BILLING=
ANYTHINK_DEV_ORG_ID=

# Local development environment
ANYTHINK_LOCAL_API=
ANYTHINK_LOCAL_BILLING=
ANYTHINK_LOCAL_ORG_ID=
